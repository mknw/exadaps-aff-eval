# Root directory for all data (raw downloads, consolidated, generated)
DATA_ROOT=./data

# Seed for all random operations — change to get different splits
PIPELINE_SEED=42

# Log level: DEBUG | INFO | WARNING
PIPELINE_LOG_LEVEL=INFO

# Optional: redirect HuggingFace dataset cache
# HF_HOME=./data/raw/.hf_cache

# Set to 1 in CI to skip HuggingFace dataset downloads
# HF_DATASETS_OFFLINE=1
